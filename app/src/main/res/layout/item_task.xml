<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    style="@style/Widget.AfriNuts.CardView"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Icon + Title + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/tvTaskIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_tractor"
                app:tint="@color/primary"
                android:background="@color/warm_grey"
                android:padding="12dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="Task icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTaskTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear Block A1"
                    style="@style/Text.H5"
                    android:textColor="@color/text_dark" />

                <TextView
                    android:id="@+id/tvTaskScope"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Block A1"
                    style="@style/Text.Caption" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvTaskStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.AfriNuts.StatusBadge"
                android:text="Pending" />

        </LinearLayout>

        <!-- Description (if available) -->
        <TextView
            android:id="@+id/tvTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear land for planting cashew trees"
            style="@style/Text.Body.Small"
            android:layout_marginBottom="12dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Bottom Row: Due Date + Overdue Warning -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/warm_grey"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_today"
                    app:tint="@color/navy"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Due date" />

                <TextView
                    android:id="@+id/tvDueDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Due: Mar 15, 2024"
                    style="@style/Text.Caption" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:id="@+id/overdueLayout">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_warning"
                    app:tint="@android:color/holo_red_dark"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Overdue warning" />

                <TextView
                    android:id="@+id/tvOverdueWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overdue"
                    style="@style/Text.Caption.Small"
                    android:textColor="@android:color/holo_red_dark" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>