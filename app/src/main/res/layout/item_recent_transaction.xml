<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    style="@style/Widget.AfriNuts.CardView"
    app:cardElevation="2dp"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTransactionIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="💰"
            android:textSize="24sp"
            android:background="@color/warm_grey"
            android:backgroundTint="@color/warm_grey"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTransactionDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium Grade Revenue"
                style="@style/Text.Body"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <TextView
                android:id="@+id/tvTransactionDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mar 15, 2024"
                style="@style/Text.Caption.Small"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTransactionAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+525,000 XAF"
            style="@style/Text.Label"
            android:textColor="@android:color/holo_green_dark" />

    </LinearLayout>

</androidx.cardview.widget.CardView>