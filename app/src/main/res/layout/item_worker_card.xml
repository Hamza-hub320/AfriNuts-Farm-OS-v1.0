<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    style="@style/Widget.AfriNuts.CardView"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Worker Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvWorkerIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="👤"
                android:textSize="24sp"
                android:background="@color/warm_grey"
                android:backgroundTint="@color/warm_grey"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWorkerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Doe"
                    style="@style/Text.H4" />

                <TextView
                    android:id="@+id/tvWorkerStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 tasks • 3 completed"
                    style="@style/Text.Caption" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvCompletionRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="75%"
                style="@style/Text.Stat.Small"
                android:background="@color/warm_grey"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/workerProgress"
            style="@style/Widget.AfriNuts.ProgressBar"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:progress="75"
            android:max="100"
            android:layout_marginBottom="12dp" />

        <!-- Task Type Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/taskTypeContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- Time Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/warm_grey"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏱️ Total Time"
                style="@style/Text.Caption.Small" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2d 4h"
                style="@style/Text.Label.Small"
                android:textColor="@color/primary"
                android:layout_marginEnd="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏲️ Avg"
                style="@style/Text.Caption.Small" />

            <TextView
                android:id="@+id/tvAvgTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3h"
                style="@style/Text.Label.Small"
                android:textColor="@color/primary"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>