<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.AfriNuts.CardView"
    app:cardElevation="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:padding="16dp">

        <!-- Info Badge -->
        <FrameLayout
            android:id="@+id/infoBadge"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:background="@drawable/badge_background"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="i"
                style="@style/Text.Overline"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

        </FrameLayout>

        <!-- Gradient Background -->
        <View
            android:id="@+id/gradientOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_card_primary" />

        <!-- 3D Edge Effect -->
        <View
            android:id="@+id/edgeEffect"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/card_edge_effect" />

        <!-- Glassy Overlay -->
        <View
            android:id="@+id/glassOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/card_glass_overlay" />

        <!-- Inner Shadow -->
        <View
            android:id="@+id/innerShadow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/card_inner_shadow" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Icon -->
            <ImageView
                android:id="@+id/iconView"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/icon_background"
                android:padding="12dp"
                android:visibility="gone"
                android:src="@drawable/ic_farm"
                app:tint="@color/primary" />

            <!-- Title -->
            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Card Title"
                style="@style/Text.H3"
                android:textColor="@color/primary"
                android:layout_marginBottom="4dp" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/subtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subtitle"
                style="@style/Text.Body.Small"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Dynamic Content Container -->
            <FrameLayout
                android:id="@+id/contentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />

            <!-- CTA Button -->
            <LinearLayout
                android:id="@+id/ctaContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/cta_background"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/ctaText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Action"
                    style="@style/Text.Button"
                    android:textColor="@android:color/white" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="@android:color/white"
                    android:layout_marginStart="8dp"
                    android:contentDescription="Arrow" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>