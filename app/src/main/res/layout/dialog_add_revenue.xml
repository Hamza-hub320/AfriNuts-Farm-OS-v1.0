<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Dialog Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Harvest Revenue"
            style="@style/Text.H2"
            android:textColor="@color/primary"
            android:layout_marginBottom="16dp" />

        <!-- Quantity (kg) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.AfriNuts.EditText">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etQuantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Quantity (kg)"
                android:inputType="numberDecimal" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Price per kg -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.AfriNuts.EditText">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPricePerKg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Price per kg (XAF)"
                android:inputType="numberDecimal" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Harvest Date -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.AfriNuts.EditText"
            app:endIconMode="clear_text"
            app:endIconDrawable="@drawable/ic_today">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHarvestDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Harvest Date"
                android:focusable="false"
                android:clickable="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Revenue Type: Block-specific or Processing Center -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleRevenueType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true">

            <Button
                android:id="@+id/btnPerBlock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Per Block"
                style="@style/Widget.AfriNuts.Button.Outlined"
                app:icon="@drawable/ic_inventory"
                app:iconGravity="textStart" />

            <Button
                android:id="@+id/btnProcessingCenter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Processing Center"
                style="@style/Widget.AfriNuts.Button.Outlined"
                app:icon="@drawable/ic_business"
                app:iconGravity="textStart" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Block Selector (visible only when "Per Block" is selected) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutBlockSelector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="visible"
            style="@style/Widget.AfriNuts.EditText"
            android:hint="Select Block"
            app:endIconMode="dropdown_menu"
            app:endIconDrawable="@drawable/ic_arrow_drop_down">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/etBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:drawableStart="@drawable/ic_inventory"
                android:drawablePadding="8dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Quality Grade -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.AfriNuts.EditText"
            android:hint="Quality Grade"
            app:endIconMode="dropdown_menu"
            app:endIconDrawable="@drawable/ic_arrow_drop_down">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/etQuality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:drawableStart="@drawable/ic_star"
                android:drawablePadding="8dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Buyer -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.AfriNuts.EditText"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBuyer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buyer (optional)"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="8dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Notes -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            style="@style/Widget.AfriNuts.EditText">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Notes (optional)"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:drawableStart="@drawable/ic_note"
                android:drawablePadding="8dp"
                android:drawableTint="@color/navy" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Total Amount Preview -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            style="@style/Widget.AfriNuts.CardView"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:background="@color/warm_grey">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_attach_money"
                    app:tint="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Amount:"
                    style="@style/Text.Label" />

                <TextView
                    android:id="@+id/tvTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 XAF"
                    style="@style/Text.Stat.Small" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                style="@style/Widget.AfriNuts.Button.Outlined"
                android:layout_marginEnd="8dp"
                app:icon="@drawable/ic_cancel"
                app:iconGravity="textStart" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save Revenue"
                style="@style/Widget.AfriNuts.Button"
                app:icon="@drawable/ic_save"
                app:iconGravity="textStart" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>