<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:titleTextColor="@android:color/white"
        app:navigationIconTint="@android:color/white"
        app:title="Harvest Revenue" />

    <!-- Summary Cards Row (2 columns) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:weightSum="2">

        <!-- Total Revenue Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            style="@style/Widget.AfriNuts.CardView"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <ImageView
                    android:layout_width="28sp"
                    android:layout_height="28sp"
                    android:src="@drawable/ic_attach_money"
                    app:tint="@color/primary"
                    android:contentDescription="Revenue icon" />

                <TextView
                    android:id="@+id/totalRevenueValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 XAF"
                    style="@style/Text.Stat.Small"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Revenue"
                    style="@style/Text.Caption.Small" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Total Harvest Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            style="@style/Widget.AfriNuts.CardView"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <ImageView
                    android:layout_width="28sp"
                    android:layout_height="28sp"
                    android:src="@drawable/ic_inventory"
                    app:tint="@color/primary"
                    android:contentDescription="Harvest icon" />

                <TextView
                    android:id="@+id/totalHarvestValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 kg"
                    style="@style/Text.Stat.Small"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Harvest"
                    style="@style/Text.Caption.Small" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:scrollbars="none"
        android:fadingEdgeLength="20dp"
        android:requiresFadingEdge="horizontal">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/filterChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:paddingVertical="4dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacing="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Revenue"
                android:checked="true"
                style="@style/Widget.AfriNuts.Chip" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBlocks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blocks"
                style="@style/Widget.AfriNuts.Chip" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipProcessing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Processing"
                style="@style/Widget.AfriNuts.Chip" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPremium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium"
                app:chipIcon="@drawable/ic_star"
                app:chipIconTint="@color/accent"
                app:iconStartPadding="4dp"
                style="@style/Widget.AfriNuts.Chip" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStandard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Standard"
                app:chipIcon="@drawable/ic_check_circle"
                app:chipIconTint="@color/primary"
                app:iconStartPadding="4dp"
                style="@style/Widget.AfriNuts.Chip" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AfriNuts.ProgressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="64dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_grass"
            app:tint="@color/warm_grey"
            android:contentDescription="Empty state" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No harvest records yet"
            style="@style/Text.H4"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap + to add your first harvest"
            style="@style/Text.Body.Small"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        android:visibility="gone" />

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddRevenue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Add revenue"
        app:backgroundTint="@color/accent"
        app:tint="@android:color/white" />

</LinearLayout>