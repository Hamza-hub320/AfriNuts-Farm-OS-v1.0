<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    style="@style/Widget.AfriNuts.CardView"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Icon + Quality + Amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvQualityIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="⭐"
                style="@style/Text.Display.Small"
                android:background="@color/warm_grey"
                android:padding="8dp"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Premium Grade"
                    style="@style/Text.H5" />

                <TextView
                    android:id="@+id/tvSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Block A1"
                    style="@style/Text.Body.Small" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="525,000 XAF"
                style="@style/Text.Stat.Small" />

        </LinearLayout>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/warm_grey"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvQuantity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📦 350 kg"
                style="@style/Text.Caption"
                android:drawableStart="@android:drawable/ic_menu_gallery"
                android:drawablePadding="4dp" />

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💰 1,500 XAF/kg"
                style="@style/Text.Caption"
                android:drawableStart="@android:drawable/ic_menu_send"
                android:drawablePadding="4dp" />

        </LinearLayout>

        <!-- Bottom Row: Date + Buyer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📅 Mar 15, 2024"
                style="@style/Text.Caption.Small"
                android:drawableStart="@android:drawable/ic_menu_today"
                android:drawablePadding="4dp" />

            <TextView
                android:id="@+id/tvBuyer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="👤 Olam"
                style="@style/Text.Caption.Small"
                android:gravity="end"
                android:drawableEnd="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="4dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>