<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Icon at top -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_people"
        app:tint="@color/primary"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp"
        android:contentDescription="Worker icon" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Assign Worker to Task"
        style="@style/Text.H5"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select or enter worker name"
        style="@style/Text.Body.Small"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Existing Worker Dropdown -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        style="@style/Widget.AfriNuts.EditText"
        android:hint="Select existing worker"
        app:endIconMode="dropdown_menu"
        app:startIconDrawable="@drawable/ic_people"
        app:startIconTint="@color/primary">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/etWorkerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            style="@style/Text.Body" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OR"
        style="@style/Text.Overline"
        android:textColor="@color/navy"
        android:gravity="center"
        android:layout_marginVertical="16dp" />

    <!-- New Worker Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        style="@style/Widget.AfriNuts.EditText"
        android:hint="Enter new worker name"
        app:startIconDrawable="@drawable/ic_person"
        app:startIconTint="@color/primary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNewWorker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName"
            style="@style/Text.Body" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Note: The dialog's positive/negative buttons are handled in code,
         so we don't need to add them here -->

</LinearLayout>