<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:titleTextColor="@android:color/white"
        app:navigationIconTint="@android:color/white"
        app:title="Revenue Details" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Quality Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.AfriNuts.CardView"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/tvQualityIcon"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_star"
                        app:tint="@color/accent"
                        android:background="@color/warm_grey"
                        android:padding="16dp"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="Quality grade icon" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvQualityGrade"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Premium Grade"
                            style="@style/Text.H3" />

                        <TextView
                            android:id="@+id/tvSource"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Block A1"
                            style="@style/Text.Body.Small"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Details Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.AfriNuts.CardView"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_grain"
                            app:tint="@color/primary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Harvest Details"
                            style="@style/Text.H4"
                            android:textColor="@color/text_dark" />

                    </LinearLayout>

                    <!-- Quantity -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Quantity:"
                            style="@style/Text.Label" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_weight"
                                app:tint="@color/navy"
                                android:layout_marginEnd="4dp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvQuantity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="350 kg"
                                style="@style/Text.Body" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Price per kg -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Price/kg:"
                            style="@style/Text.Label" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_attach_money"
                                app:tint="@color/navy"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/tvPricePerKg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1,500 XAF"
                                style="@style/Text.Body" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Total Amount -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:background="@color/warm_grey"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_calculator"
                            app:tint="@color/primary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Total:"
                            style="@style/Text.Label" />

                        <TextView
                            android:id="@+id/tvTotalAmount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="525,000 XAF"
                            style="@style/Text.Stat"
                            android:textColor="@color/primary"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- Harvest Date -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Harvest Date:"
                            style="@style/Text.Label" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_today"
                                app:tint="@color/navy"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/tvHarvestDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mar 15, 2024"
                                style="@style/Text.Body" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Buyer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Buyer:"
                            style="@style/Text.Label" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_person"
                                app:tint="@color/navy"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/tvBuyer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Olam"
                                style="@style/Text.Body" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Notes (if available) -->
                    <LinearLayout
                        android:id="@+id/notesLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/warm_grey"
                        android:padding="12dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_note"
                            app:tint="@color/navy"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="top" />

                        <TextView
                            android:id="@+id/tvNotes"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Premium quality harvest from Block A1"
                            style="@style/Text.Body.Small" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Delete Button -->
            <Button
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Delete Revenue Record"
                style="@style/Widget.AfriNuts.Button"
                android:backgroundTint="@android:color/holo_red_dark"
                app:icon="@drawable/ic_delete"
                app:iconGravity="textStart"
                app:iconTint="@android:color/white"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>