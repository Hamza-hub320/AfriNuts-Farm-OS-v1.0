<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="GradientCardView">
        <attr name="cardTitle" format="string" />
        <attr name="cardSubtitle" format="string" />
        <attr name="cardIcon" format="reference" />
        <attr name="cardVariant" format="enum">
            <enum name="primary" value="0" />
            <enum name="accent" value="1" />
            <enum name="secondary" value="2" />
        </attr>
        <attr name="showInfoBadge" format="boolean" />
        <attr name="ctaText" format="string" />
    </declare-styleable>
</resources>